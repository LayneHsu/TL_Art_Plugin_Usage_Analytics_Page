{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tl-art-tool-usage-analytics.invalid/contracts/usage-event-schema.json",
  "title": "TL Art Tool Usage Event",
  "description": "Client event and Firestore error-log contract for the Spark collector.",
  "type": "object",
  "x-company-timezone": "Asia/Shanghai",
  "x-shard-count": 32,
  "x-max-events-per-shard": 500,
  "x-max-event-json-bytes": 1536,
  "x-max-shard-json-bytes": 917504,
  "x-max-stack-utf8-bytes": 8192,
  "x-event-types": [
    "entry_clicked",
    "dialog_opened",
    "dialog_open_failed",
    "run_rejected",
    "run_started",
    "run_succeeded",
    "run_failed",
    "run_cancelled",
    "run_interrupted",
    "unexpected_exception"
  ],
  "x-usage-counted-event-type": "run_started",
  "$ref": "#/$defs/event",
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "stableKey": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "semanticVersion": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)(?:-(?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*))*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "eventType": {
      "enum": [
        "entry_clicked",
        "dialog_opened",
        "dialog_open_failed",
        "run_rejected",
        "run_started",
        "run_succeeded",
        "run_failed",
        "run_cancelled",
        "run_interrupted",
        "unexpected_exception"
      ]
    },
    "result": {
      "enum": ["started", "succeeded", "failed", "rejected", "cancelled", "interrupted", "unexpected"]
    },
    "redactedSummary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^[^\\r\\n]+$",
      "allOf": [
        { "not": { "pattern": "[A-Za-z]:[\\\\/]" } },
        { "not": { "pattern": "\\\\\\\\" } },
        { "not": { "pattern": "(?:^|[\\s'(=])/(?:[A-Za-z0-9._~-]+/)*[A-Za-z0-9._~-]+" } },
        { "not": { "pattern": "[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}" } },
        { "not": { "pattern": "[A-Za-z0-9_-]{8,}\\.[A-Za-z0-9_-]{8,}\\.[A-Za-z0-9_-]{8,}" } },
        { "not": { "pattern": "[Bb][Ee][Aa][Rr][Ee][Rr]\\s+[^\\s]+" } },
        { "not": { "pattern": "(?:[Rr][Ee][Qq][Uu][Ee][Ss][Tt]|[Rr][Ee][Ss][Pp][Oo][Nn][Ss][Ee])\\s+[Bb][Oo][Dd][Yy]\\s*[:=]" } },
        { "not": { "pattern": "(?:^|[^A-Za-z0-9_-])(?:[A-Za-z0-9_-]*_)?(?:[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Cc][Oo][Oo][Kk][Ii][Ee]|[Tt][Oo][Kk][Ee][Nn]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Pp][Aa][Ss][Ss][Ww][Dd]|[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll]|[Aa][Pp][Ii](?:[_-]?[Kk][Ee][Yy])|[Pp][Rr][Ii][Vv][Aa][Tt][Ee](?:[_-]?[Kk][Ee][Yy]))[^A-Za-z0-9_-]{0,3}[:=]\\s*[^\\s]+" } }
      ]
    },
    "stack": {
      "type": "string",
      "minLength": 1,
      "maxLength": 8192,
      "x-max-utf8-bytes": 8192,
      "allOf": [
        { "not": { "pattern": "[A-Za-z]:[\\\\/]" } },
        { "not": { "pattern": "\\\\\\\\" } },
        { "not": { "pattern": "(?:^|[\\s'(=])/(?:[A-Za-z0-9._~-]+/)*[A-Za-z0-9._~-]+" } },
        { "not": { "pattern": "[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}" } },
        { "not": { "pattern": "[A-Za-z0-9_-]{8,}\\.[A-Za-z0-9_-]{8,}\\.[A-Za-z0-9_-]{8,}" } },
        { "not": { "pattern": "[Bb][Ee][Aa][Rr][Ee][Rr]\\s+[^\\s]+" } },
        { "not": { "pattern": "(?:[Rr][Ee][Qq][Uu][Ee][Ss][Tt]|[Rr][Ee][Ss][Pp][Oo][Nn][Ss][Ee])\\s+[Bb][Oo][Dd][Yy]\\s*[:=]" } },
        { "not": { "pattern": "(?:^|[^A-Za-z0-9_-])(?:[A-Za-z0-9_-]*_)?(?:[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Bb][Ee][Aa][Rr][Ee][Rr]|[Cc][Oo][Oo][Kk][Ii][Ee]|[Tt][Oo][Kk][Ee][Nn]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Pp][Aa][Ss][Ss][Ww][Dd]|[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll]|[Aa][Pp][Ii](?:[_-]?[Kk][Ee][Yy])|[Pp][Rr][Ii][Vv][Aa][Tt][Ee](?:[_-]?[Kk][Ee][Yy]))[^A-Za-z0-9_-]{0,3}[:=]\\s*[^\\s]+" } }
      ]
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "operation_id",
        "tool_key",
        "action_key",
        "event_type",
        "occurred_at",
        "result",
        "plugin_version"
      ],
      "properties": {
        "event_id": { "$ref": "#/$defs/identifier" },
        "operation_id": { "$ref": "#/$defs/identifier" },
        "tool_key": { "$ref": "#/$defs/stableKey" },
        "action_key": { "$ref": "#/$defs/stableKey" },
        "event_type": { "$ref": "#/$defs/eventType" },
        "occurred_at": { "type": "string", "format": "date-time" },
        "result": { "$ref": "#/$defs/result" },
        "duration_ms": { "type": "integer", "minimum": 0, "maximum": 604800000 },
        "plugin_version": { "$ref": "#/$defs/semanticVersion" },
        "error_log_id": { "$ref": "#/$defs/identifier" },
        "error_summary": { "$ref": "#/$defs/redactedSummary" }
      },
      "allOf": [
        {
          "if": { "properties": { "event_type": { "enum": ["run_succeeded", "run_failed", "run_cancelled", "run_interrupted"] } }, "required": ["event_type"] },
          "then": { "required": ["duration_ms"], "properties": { "duration_ms": { "type": "integer", "minimum": 0, "maximum": 604800000 } } }
        },
        {
          "if": { "properties": { "event_type": { "enum": ["entry_clicked", "dialog_opened", "dialog_open_failed", "run_rejected", "run_started", "unexpected_exception"] } }, "required": ["event_type"] },
          "then": { "not": { "required": ["duration_ms"] } }
        },
        {
          "if": { "required": ["error_log_id"], "properties": { "error_log_id": {} } },
          "then": { "required": ["error_summary"], "properties": { "error_summary": { "$ref": "#/$defs/redactedSummary" } } }
        },
        {
          "if": { "required": ["error_summary"], "properties": { "error_summary": {} } },
          "then": { "required": ["error_log_id"], "properties": { "error_log_id": { "$ref": "#/$defs/identifier" } } }
        },
        {
          "if": { "properties": { "event_type": { "const": "entry_clicked" } }, "required": ["event_type"] },
          "then": { "properties": { "result": { "const": "started" } } }
        },
        {
          "if": { "properties": { "event_type": { "const": "dialog_opened" } }, "required": ["event_type"] },
          "then": { "properties": { "result": { "const": "started" } } }
        },
        {
          "if": { "properties": { "event_type": { "const": "dialog_open_failed" } }, "required": ["event_type"] },
          "then": { "properties": { "result": { "const": "failed" } } }
        },
        {
          "if": { "properties": { "event_type": { "const": "run_rejected" } }, "required": ["event_type"] },
          "then": { "properties": { "result": { "const": "rejected" } } }
        },
        {
          "if": { "properties": { "event_type": { "const": "run_started" } }, "required": ["event_type"] },
          "then": { "properties": { "result": { "const": "started" } } }
        },
        {
          "if": { "properties": { "event_type": { "const": "run_succeeded" } }, "required": ["event_type"] },
          "then": { "properties": { "result": { "const": "succeeded" } } }
        },
        {
          "if": { "properties": { "event_type": { "const": "run_failed" } }, "required": ["event_type"] },
          "then": { "properties": { "result": { "const": "failed" } } }
        },
        {
          "if": { "properties": { "event_type": { "const": "run_cancelled" } }, "required": ["event_type"] },
          "then": { "properties": { "result": { "const": "cancelled" } } }
        },
        {
          "if": { "properties": { "event_type": { "const": "run_interrupted" } }, "required": ["event_type"] },
          "then": { "properties": { "result": { "const": "interrupted" } } }
        },
        {
          "if": { "properties": { "event_type": { "const": "unexpected_exception" } }, "required": ["event_type"] },
          "then": { "properties": { "result": { "const": "unexpected" } } }
        }
      ]
    },
    "pluginUser": {
      "type": "object",
      "additionalProperties": false,
      "required": ["uid", "email", "display_name", "avatar_url", "last_login_at", "last_active_at", "plugin_version", "updated_at"],
      "properties": {
        "uid": { "$ref": "#/$defs/identifier" },
        "email": { "type": "string", "minLength": 3, "maxLength": 254, "pattern": "^[A-Za-z0-9._%+-]+@xindong\\.com$" },
        "display_name": { "type": "string", "minLength": 1, "maxLength": 128 },
        "avatar_url": { "type": "string", "maxLength": 2048 },
        "last_login_at": { "type": "string", "format": "date-time" },
        "last_active_at": { "type": "string", "format": "date-time" },
        "plugin_version": { "$ref": "#/$defs/semanticVersion" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "portalMember": {
      "type": "object",
      "additionalProperties": false,
      "required": ["email", "role", "enabled", "created_at", "created_by", "updated_at", "updated_by"],
      "properties": {
        "email": { "type": "string", "minLength": 3, "maxLength": 254, "pattern": "^(?:[a-z0-9._%+-]+@xindong\\.com|snkhtm@gmail\\.com)$" },
        "role": { "enum": ["admin", "viewer"] },
        "enabled": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" },
        "created_by": { "$ref": "#/$defs/identifier" },
        "updated_at": { "type": "string", "format": "date-time" },
        "updated_by": { "$ref": "#/$defs/identifier" }
      }
    },
    "dailyShard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "company_date",
        "uid",
        "tool_key",
        "shard",
        "events",
        "first_occurred_at",
        "last_occurred_at",
        "last_result",
        "plugin_version"
      ],
      "properties": {
        "company_date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
        "uid": { "$ref": "#/$defs/identifier" },
        "tool_key": { "$ref": "#/$defs/stableKey" },
        "shard": { "type": "string", "pattern": "^(0[0-9]|[12][0-9]|3[01])$" },
        "events": {
          "type": "array",
          "minItems": 1,
          "maxItems": 500,
          "items": { "$ref": "#/$defs/event" }
        },
        "first_occurred_at": { "type": "string", "format": "date-time" },
        "last_occurred_at": { "type": "string", "format": "date-time" },
        "last_result": { "$ref": "#/$defs/result" },
        "plugin_version": { "$ref": "#/$defs/semanticVersion" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "errorLog": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "uid",
        "company_date",
        "tool_key",
        "action_key",
        "occurred_at",
        "error_type",
        "summary",
        "call_site",
        "fingerprint",
        "stack",
        "plugin_version"
      ],
      "properties": {
        "event_id": { "$ref": "#/$defs/identifier" },
        "uid": { "$ref": "#/$defs/identifier" },
        "company_date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
        "tool_key": { "$ref": "#/$defs/stableKey" },
        "action_key": { "$ref": "#/$defs/stableKey" },
        "occurred_at": { "type": "string", "format": "date-time" },
        "error_type": { "enum": ["validation", "permission", "dependency", "timeout", "ue_runtime", "houdini_runtime", "cancelled", "internal", "unknown"] },
        "summary": { "$ref": "#/$defs/redactedSummary" },
        "call_site": { "$ref": "#/$defs/stableKey" },
        "fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "stack": { "$ref": "#/$defs/stack" },
        "plugin_version": { "$ref": "#/$defs/semanticVersion" }
      }
    }
  }
}
