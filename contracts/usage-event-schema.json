{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tl-art-tool-usage-analytics.invalid/contracts/usage-event-schema.json",
  "title": "TL Art Tool Usage Event",
  "description": "Authoritative client and stored usage-event contract.",
  "type": "object",
  "x-event-types": [
    "entry_clicked",
    "dialog_opened",
    "dialog_open_failed",
    "run_rejected",
    "run_started",
    "run_succeeded",
    "run_failed",
    "run_cancelled",
    "run_interrupted",
    "unexpected_exception"
  ],
  "x-usage-counted-event-type": "run_started",
  "x-time-policy": {
    "company_timezone": "Asia/Shanghai",
    "utc_offset_minutes": 480,
    "observes_daylight_saving_time": false,
    "max_client_behind_ms": 2592000000,
    "max_client_ahead_ms": 86400000,
    "permanent_rejection_outside_hard_range": true,
    "correct_if_client_ahead_over_ms": 600000,
    "correct_if_client_behind_over_ms": 604800000,
    "correction_target": "server_received_at",
    "bucket_time_field": "corrected_observed_at"
  },
  "x-operation-recovery-policy": {
    "startup_recovery_event_type": "run_interrupted",
    "startup_recovery_requires_persisted_operation": true,
    "startup_recovery_requires_missing_terminal": true,
    "startup_recovery_idempotency_scope": [
      "operation_id",
      "run_interrupted"
    ],
    "abandoned_after_ms": 86400000,
    "abandoned_is_derived_display_state": true,
    "source_event_type_is_immutable": true,
    "later_run_interrupted_supersedes_abandoned": true
  },
  "$ref": "#/$defs/clientEvent",
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "stableKey": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "semanticVersion": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)(?:-(?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*))*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "eventType": {
      "enum": [
        "entry_clicked",
        "dialog_opened",
        "dialog_open_failed",
        "run_rejected",
        "run_started",
        "run_succeeded",
        "run_failed",
        "run_cancelled",
        "run_interrupted",
        "unexpected_exception"
      ]
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["error_category", "summary", "call_site", "fingerprint"],
      "properties": {
        "error_category": {
          "enum": [
            "validation",
            "permission",
            "dependency",
            "timeout",
            "ue_runtime",
            "houdini_runtime",
            "cancelled",
            "internal",
            "unknown"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512,
          "pattern": "^[^\\r\\n]+$",
          "allOf": [
            {
              "not": {
                "pattern": "[Tt][Rr][Aa][Cc][Ee][Bb][Aa][Cc][Kk]"
              }
            },
            {
              "not": {
                "pattern": "[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]\\s*:"
              }
            },
            {
              "not": {
                "pattern": "(?:^|[^A-Za-z0-9_])[Bb][Ee][Aa][Rr][Ee][Rr]\\s+\\S"
              }
            },
            {
              "not": {
                "pattern": "(?:^|[^A-Za-z0-9_])[Cc][Oo][Oo][Kk][Ii][Ee]\\s*:"
              }
            },
            {
              "not": {
                "pattern": "(?:[A-Za-z]:[\\\\/]|\\\\\\\\)"
              }
            },
            {
              "not": {
                "pattern": "(?:^|[\\s\"'(=])/(?:[A-Za-z0-9._~-]+/)+[A-Za-z0-9._~-]+"
              }
            },
            {
              "not": {
                "pattern": "[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}"
              }
            },
            {
              "not": {
                "pattern": "[A-Za-z0-9_-]{8,}\\.[A-Za-z0-9_-]{8,}\\.[A-Za-z0-9_-]{8,}"
              }
            },
            {
              "not": {
                "pattern": "[Ff][Ii][Ll][Ee]\\s+[\"'][^\"'\\r\\n]+[\"']\\s*,\\s*[Ll][Ii][Nn][Ee]\\s+[0-9]+"
              }
            },
            {
              "not": {
                "pattern": "(?:^|[^A-Za-z0-9_-])[\"']?[A-Za-z0-9_-]*(?:[Tt][Oo][Kk][Ee][Nn]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Pp][Aa][Ss][Ss][Ww][Dd]|[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll]|[Aa][Pp][Ii](?:[_-]?[Kk][Ee][Yy])|[Pp][Rr][Ii][Vv][Aa][Tt][Ee](?:[_-]?[Kk][Ee][Yy]))[\"']?\\s*[:=]\\s*(?:[\"'][^\"'\\r\\n]|[^\\s\"'])"
              }
            }
          ]
        },
        "call_site": { "$ref": "#/$defs/stableKey" },
        "fingerprint": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "commonEvent": {
      "type": "object",
      "required": [
        "schema_version",
        "registry_version",
        "event_id",
        "binding_id",
        "tool_key",
        "action_key",
        "event_type",
        "client_observed_at",
        "plugin_version",
        "ue_version",
        "ui_version",
        "process_instance_id",
        "session_id",
        "operation_id"
      ],
      "properties": {
        "schema_version": { "$ref": "#/$defs/semanticVersion" },
        "registry_version": { "$ref": "#/$defs/semanticVersion" },
        "event_id": { "$ref": "#/$defs/identifier" },
        "binding_id": { "$ref": "#/$defs/identifier" },
        "tool_key": { "$ref": "#/$defs/stableKey" },
        "action_key": { "$ref": "#/$defs/stableKey" },
        "event_type": { "$ref": "#/$defs/eventType" },
        "client_observed_at": { "type": "string", "format": "date-time" },
        "plugin_version": { "$ref": "#/$defs/semanticVersion" },
        "ue_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[0-9]{1,3}\\.[0-9]{1,3}(?:\\.[0-9]{1,10})?(?:[+-][A-Za-z0-9][A-Za-z0-9.+-]*)?$"
        },
        "ui_version": { "$ref": "#/$defs/semanticVersion" },
        "process_instance_id": { "$ref": "#/$defs/identifier" },
        "session_id": { "$ref": "#/$defs/identifier" },
        "operation_id": { "$ref": "#/$defs/identifier" },
        "duration_ms": {
          "type": "integer",
          "minimum": 0,
          "maximum": 604800000
        },
        "error": { "$ref": "#/$defs/error" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "duration_ms": {} },
            "required": ["duration_ms"]
          },
          "then": {
            "properties": {
              "event_type": {
                "enum": [
                  "run_succeeded",
                  "run_failed",
                  "run_cancelled",
                  "run_interrupted"
                ]
              }
            }
          }
        }
      ]
    },
    "clientEvent": {
      "type": "object",
      "allOf": [{ "$ref": "#/$defs/commonEvent" }],
      "unevaluatedProperties": false
    },
    "storedEvent": {
      "type": "object",
      "allOf": [
        { "$ref": "#/$defs/commonEvent" },
        {
          "type": "object",
          "required": [
            "plugin_principal_id",
            "server_received_at",
            "time_correction"
          ],
          "properties": {
            "plugin_principal_id": { "$ref": "#/$defs/identifier" },
            "server_received_at": { "type": "string", "format": "date-time" },
            "time_correction": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "applied",
                "corrected_observed_at",
                "clock_offset_ms",
                "reason"
              ],
              "properties": {
                "applied": { "type": "boolean" },
                "corrected_observed_at": {
                  "type": "string",
                  "format": "date-time"
                },
                "clock_offset_ms": {
                  "type": "integer",
                  "minimum": -86400000,
                  "maximum": 2592000000
                },
                "reason": {
                  "enum": [
                    "within_tolerance",
                    "client_clock_ahead",
                    "client_clock_behind"
                  ]
                }
              },
              "allOf": [
                {
                  "if": {
                    "properties": {
                      "reason": { "const": "within_tolerance" }
                    },
                    "required": ["reason"]
                  },
                  "then": {
                    "properties": {
                      "applied": { "const": false },
                      "clock_offset_ms": {
                        "type": "integer",
                        "minimum": -600000,
                        "maximum": 604800000
                      }
                    }
                  }
                },
                {
                  "if": {
                    "properties": {
                      "reason": { "const": "client_clock_ahead" }
                    },
                    "required": ["reason"]
                  },
                  "then": {
                    "properties": {
                      "applied": { "const": true },
                      "clock_offset_ms": {
                        "type": "integer",
                        "minimum": -86400000,
                        "maximum": -600001
                      }
                    }
                  }
                },
                {
                  "if": {
                    "properties": {
                      "reason": { "const": "client_clock_behind" }
                    },
                    "required": ["reason"]
                  },
                  "then": {
                    "properties": {
                      "applied": { "const": true },
                      "clock_offset_ms": {
                        "type": "integer",
                        "minimum": 604800001,
                        "maximum": 2592000000
                      }
                    }
                  }
                }
              ]
            }
          }
        }
      ],
      "unevaluatedProperties": false
    }
  }
}
