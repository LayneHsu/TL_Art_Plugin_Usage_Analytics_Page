{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tl-art-tool-usage-analytics.invalid/contracts/tool-registry.schema.json",
  "title": "TL Art Tool Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "registry_version",
    "registry_status",
    "tools"
  ],
  "properties": {
    "$schema": { "const": "./tool-registry.schema.json" },
    "schema_version": { "$ref": "#/$defs/semanticVersion" },
    "registry_version": { "$ref": "#/$defs/semanticVersion" },
    "registry_status": { "enum": ["draft", "active"] },
    "tools": {
      "type": "array",
      "items": { "$ref": "#/$defs/tool" }
    }
  },
  "$defs": {
    "semanticVersion": {
      "type": "string",
      "pattern": "^(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)(?:-(?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*))*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "stableKey": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "displayState": {
      "enum": ["active", "hidden", "retired"]
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_key",
        "display_name",
        "page",
        "introduced_version",
        "retired_version",
        "accept_until",
        "display_state"
      ],
      "properties": {
        "action_key": { "$ref": "#/$defs/stableKey" },
        "display_name": { "type": "string", "minLength": 1, "maxLength": 128 },
        "page": { "$ref": "#/$defs/stableKey" },
        "introduced_version": { "$ref": "#/$defs/semanticVersion" },
        "retired_version": {
          "anyOf": [
            { "$ref": "#/$defs/semanticVersion" },
            { "type": "null" }
          ]
        },
        "accept_until": {
          "anyOf": [
            { "type": "string", "format": "date-time" },
            { "type": "null" }
          ]
        },
        "display_state": { "$ref": "#/$defs/displayState" }
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool_key",
        "display_name",
        "page",
        "introduced_version",
        "retired_version",
        "accept_until",
        "display_state",
        "actions"
      ],
      "properties": {
        "tool_key": { "$ref": "#/$defs/stableKey" },
        "display_name": { "type": "string", "minLength": 1, "maxLength": 128 },
        "page": { "$ref": "#/$defs/stableKey" },
        "introduced_version": { "$ref": "#/$defs/semanticVersion" },
        "retired_version": {
          "anyOf": [
            { "$ref": "#/$defs/semanticVersion" },
            { "type": "null" }
          ]
        },
        "accept_until": {
          "anyOf": [
            { "type": "string", "format": "date-time" },
            { "type": "null" }
          ]
        },
        "display_state": { "$ref": "#/$defs/displayState" },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/action" }
        }
      }
    }
  }
}
