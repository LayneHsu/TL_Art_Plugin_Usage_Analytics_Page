{
  "name": "@tl-art-tool-usage-analytics/functions",
  "version": "0.1.0",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": ">=22.12.0 <23"
  },
  "scripts": {
    "build": "npm run clean && node scripts/copy-contracts.mjs && tsc -p tsconfig.json",
    "test:plugin-auth": "tsx --test test/**/*.test.ts",
    "test:usage": "tsx --test test/usage-*.test.ts",
    "test:usage-emulator": "tsx --test --test-concurrency=1 emulator-test/usage-*.emulator.ts",
    "test:portal-emulator": "tsx --test --test-concurrency=1 emulator-test/portal-firestore.emulator.ts",
    "test:emulator": "tsx --test --test-concurrency=1 emulator-test/**/*.emulator.ts",
    "clean": "node -e \"require('node:fs').rmSync('lib', { recursive: true, force: true })\""
  },
  "dependencies": {
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "firebase-admin": "14.2.0",
    "firebase-functions": "7.3.0",
    "google-auth-library": "10.9.0",
    "semver": "7.8.5"
  },
  "devDependencies": {
    "tsx": "4.23.1",
    "typescript": "^5.9.3"
  }
}
