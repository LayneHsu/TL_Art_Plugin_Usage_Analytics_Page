rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedCompanyUser() {
      return request.auth != null
        && request.auth.token.email is string
        && request.auth.token.email_verified == true
        && request.auth.token.email.matches('^[A-Za-z0-9._%+-]+@xindong\\.com$');
    }

    function portalEmail(email) {
      return email is string
        && (
          email.matches('^[A-Za-z0-9._%+-]+@xindong\\.com$')
          || email.lower() == 'snkhtm@gmail.com'
        );
    }

    function signedPortalUser() {
      return request.auth != null
        && request.auth.token.email is string
        && request.auth.token.email_verified == true
        && portalEmail(request.auth.token.email);
    }

    function memberPath() {
      return /databases/$(database)/documents/portalMembers/$(request.auth.token.email.lower());
    }

    function activePortalMember() {
      return signedPortalUser()
        && exists(memberPath())
        && get(memberPath()).data.enabled == true
        && get(memberPath()).data.role in ['admin', 'viewer'];
    }

    function activeAdmin() {
      return activePortalMember() && get(memberPath()).data.role == 'admin';
    }

    function ownPortalMember(memberId) {
      return signedPortalUser() && memberId == request.auth.token.email.lower();
    }

    function isOwnUid(uid) {
      return signedCompanyUser() && request.auth.uid == uid;
    }

    function validPluginUser(uid) {
      return request.resource.data.keys().hasOnly([
          'uid', 'email', 'display_name', 'avatar_url',
          'last_login_at', 'last_active_at', 'plugin_version', 'updated_at'
        ])
        && request.resource.data.keys().hasAll([
          'uid', 'email', 'display_name', 'avatar_url',
          'last_login_at', 'last_active_at', 'plugin_version', 'updated_at'
        ])
        && request.resource.data.uid == uid
        && request.resource.data.email is string
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.email.matches('^[A-Za-z0-9._%+-]+@xindong\\.com$');
    }

    function validDailyDimensions(documentId) {
      return request.resource.data.keys().hasOnly([
          'company_date', 'uid', 'tool_key', 'shard', 'events',
          'first_occurred_at', 'last_occurred_at', 'last_result',
          'plugin_version', 'updated_at'
        ])
        && request.resource.data.keys().hasAll([
          'company_date', 'uid', 'tool_key', 'shard', 'events',
          'first_occurred_at', 'last_occurred_at', 'last_result',
          'plugin_version', 'updated_at'
        ])
        && request.resource.data.company_date is string
        && request.resource.data.company_date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.tool_key is string
        && request.resource.data.tool_key.matches('^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$')
        && request.resource.data.shard is string
        && request.resource.data.shard.matches('^(0[0-9]|[12][0-9]|3[01])$')
        && documentId == request.resource.data.company_date + '_' + request.resource.data.uid + '_' + request.resource.data.tool_key + '_' + request.resource.data.shard
        && request.resource.data.events is list
        && request.resource.data.events.size() > 0
        && request.resource.data.events.size() <= 500;
    }

    // Rules cannot iterate an arbitrary event list. Validate the first event on
    // create; the shared schema validates every event before the client writes
    // the batch, and updates only append immutable existing events.
    function escapedToolKey(toolKey) {
      return toolKey.replace('\\.', '[.]');
    }

    function validEventMap(eventValue, documentToolKey) {
      return eventValue is map
        && eventValue.keys().hasOnly([
          'event_id', 'operation_id', 'tool_key', 'action_key',
          'event_type', 'occurred_at', 'result', 'duration_ms',
          'plugin_version', 'error_log_id', 'error_summary'
        ])
        && eventValue.keys().hasAll([
          'event_id', 'operation_id', 'tool_key', 'action_key',
          'event_type', 'occurred_at', 'result', 'plugin_version'
        ])
        && eventValue.event_id is string
        && eventValue.event_id.size() > 0
        && eventValue.event_id.size() <= 128
        && eventValue.operation_id is string
        && eventValue.operation_id.size() > 0
        && eventValue.operation_id.size() <= 128
        && eventValue.tool_key == documentToolKey
        && eventValue.action_key is string
        && eventValue.action_key.matches('^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$')
        && eventValue.action_key.matches('^' + escapedToolKey(documentToolKey) + '[.][a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$')
        && eventValue.event_type is string
        && eventValue.event_type.matches('^(entry_clicked|dialog_opened|dialog_open_failed|run_rejected|run_started|run_succeeded|run_failed|run_cancelled|run_interrupted|unexpected_exception)$')
        && eventValue.occurred_at is string
        && eventValue.occurred_at.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{1,9})?Z$')
        && eventValue.result is string
        && eventValue.result.matches('^(started|succeeded|failed|rejected|cancelled|interrupted|unexpected)$')
        && eventValue.plugin_version is string
        && eventValue.plugin_version.matches('^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][A-Za-z0-9.+-]+)?$')
        && (eventValue.event_type.matches('^run_(succeeded|failed|cancelled|interrupted)$') == eventValue.keys().hasAny(['duration_ms']))
        && (!eventValue.keys().hasAny(['duration_ms'])
          || (eventValue.duration_ms is int && eventValue.duration_ms >= 0 && eventValue.duration_ms <= 604800000))
        && (eventValue.keys().hasAny(['error_log_id']) == eventValue.keys().hasAny(['error_summary']))
        && (!eventValue.keys().hasAny(['error_log_id']) || (
          eventValue.error_log_id is string
          && eventValue.error_summary is string
          && eventValue.error_summary.size() > 0
          && eventValue.error_summary.size() <= 512
        ));
    }

    function validDailyCreate() {
      return validEventMap(request.resource.data.events[0], request.resource.data.tool_key);
    }

    function immutableDailyDimensions() {
      return resource.data.company_date == request.resource.data.company_date
        && resource.data.uid == request.resource.data.uid
        && resource.data.tool_key == request.resource.data.tool_key
        && resource.data.shard == request.resource.data.shard
        && request.resource.data.events.size() >= resource.data.events.size()
        && request.resource.data.events.hasAll(resource.data.events);
    }

    function validErrorLog(documentId) {
      return request.resource.data.keys().hasOnly([
          'event_id', 'uid', 'company_date', 'tool_key', 'action_key',
          'occurred_at', 'error_type', 'summary', 'call_site',
          'fingerprint', 'stack', 'plugin_version'
        ])
        && request.resource.data.keys().hasAll([
          'event_id', 'uid', 'company_date', 'tool_key', 'action_key',
          'occurred_at', 'error_type', 'summary', 'call_site',
          'fingerprint', 'stack', 'plugin_version'
        ])
        && request.resource.data.event_id == documentId
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.company_date is string
        && request.resource.data.company_date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && request.resource.data.tool_key is string
        && request.resource.data.tool_key.matches('^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$')
        && request.resource.data.action_key is string
        && request.resource.data.action_key.matches('^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$')
        && request.resource.data.action_key.matches('^' + escapedToolKey(request.resource.data.tool_key) + '[.][a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$')
        && request.resource.data.stack is string
        && request.resource.data.stack.toUtf8().size() <= 8192;
    }

    function validMember() {
      return request.resource.data.keys().hasOnly([
          'email', 'role', 'enabled', 'created_at', 'created_by',
          'updated_at', 'updated_by'
        ])
        && request.resource.data.keys().hasAll([
          'email', 'role', 'enabled', 'created_at', 'created_by',
          'updated_at', 'updated_by'
        ])
        && request.resource.data.email is string
        && request.resource.data.email == request.resource.data.email.lower()
        && portalEmail(request.resource.data.email)
        && request.resource.data.role in ['admin', 'viewer']
        && request.resource.data.enabled is bool;
    }

    match /pluginUsers/{uid} {
      allow get: if signedCompanyUser() && (
        (request.auth.uid == uid && resource.data.uid == uid)
        || activePortalMember()
      );
      allow list: if activePortalMember();
      allow create: if isOwnUid(uid) && validPluginUser(uid);
      allow update: if isOwnUid(uid)
        && resource.data.uid == uid
        && validPluginUser(uid);
      allow delete: if false;
    }

    match /usageDaily/{documentId} {
      allow read: if activePortalMember();
      allow create: if signedCompanyUser()
        && validDailyDimensions(documentId)
        && validDailyCreate();
      allow update: if signedCompanyUser()
        && validDailyDimensions(documentId)
        && immutableDailyDimensions();
      allow delete: if activeAdmin();
    }

    match /errorLogs/{documentId} {
      allow read: if activePortalMember();
      allow create: if signedCompanyUser() && validErrorLog(documentId);
      allow update: if signedCompanyUser()
        && validErrorLog(documentId)
        && resource.data.uid == request.auth.uid
        && resource.data.event_id == request.resource.data.event_id
        && resource.data.company_date == request.resource.data.company_date
        && resource.data.tool_key == request.resource.data.tool_key
        && resource.data.action_key == request.resource.data.action_key
        && resource.data.occurred_at == request.resource.data.occurred_at
        && resource.data.error_type == request.resource.data.error_type
        && resource.data.summary == request.resource.data.summary
        && resource.data.call_site == request.resource.data.call_site
        && resource.data.fingerprint == request.resource.data.fingerprint
        && resource.data.stack == request.resource.data.stack
        && resource.data.plugin_version == request.resource.data.plugin_version;
      allow delete: if activeAdmin();
    }

    match /portalMembers/{memberId} {
      // 查看者只能确认自己的准入记录, 管理员才可读取成员清单.
      allow get: if activeAdmin() || (activePortalMember() && ownPortalMember(memberId));
      allow list: if activeAdmin();
      allow create: if activeAdmin()
        && memberId == request.resource.data.email
        && validMember();
      allow update: if activeAdmin()
        && memberId == request.resource.data.email
        && validMember()
        && (
          memberId != request.auth.token.email.lower()
          || (
            resource.data.role == request.resource.data.role
            && resource.data.enabled == request.resource.data.enabled
          )
        );
      allow delete: if activeAdmin() && memberId != request.auth.token.email.lower();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
